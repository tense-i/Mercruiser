# Local-first workspace data file. Defaults to data/studio.json.
MERCRUISER_DATA_PATH="data/studio.json"

# Agent runtime mode: mock | google | siliconflow.
MERCRUISER_AI_MODE="mock"

# Default model name for the configured provider.
MERCRUISER_AI_MODEL="Qwen/Qwen3.5-9B"

# Either GOOGLE_GENERATIVE_AI_API_KEY or GEMINI_API_KEY can be used.
GOOGLE_GENERATIVE_AI_API_KEY=""
GEMINI_API_KEY=""

# Preferred real integration provider for this repo.
SILICONFLOW_API_KEY=""
