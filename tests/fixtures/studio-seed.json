  "sourceDocuments": [
    {
      "id": "source_episode_03",
      "episodeId": "episode_03",
      "title": "第三集原文",
      "content": "林岚在磁场错乱的废弃车站醒来，站台上的时钟全部停在不同刻度。她听见 relic 用更清晰的声音提醒她不要看向轨道尽头。巡检 Agent 的脚步声从回声里逼近，废旧广告屏开始闪烁她并不记得的童年画面。她必须在逃离、回望和追问真相之间做出第一次主动选择。",
      "importedAt": "2026-04-05T09:20:00.000Z",
      "revision": 1
    }
  ],
  "chapters": [
    {
      "id": "chapter_01_a",
      "episodeId": "episode_01",
      "index": 1,
      "title": "夜市开场",
      "content": "霓虹雨幕下，林岚穿过拥挤夜市，摊位灯箱与湿地反光构成一条压迫性的通道，她在旧物堆里听见微弱的求救声。",
      "scene": "夜市入口",
      "dialogues": [
        {
          "speaker": "旁白",
          "content": "夜市像在收紧呼吸。"
        }
      ],
      "audioStatus": "locked",
      "estimatedDurationSeconds": 28,
      "revision": 1,
      "createdAt": "2026-03-28T10:00:00.000Z",
      "updatedAt": "2026-03-29T12:00:00.000Z"
    },
    {
      "id": "chapter_01_b",
      "episodeId": "episode_01",
      "index": 2,
      "title": "遗物发声",
      "content": "她捡起 relic 的瞬间，画面中的电流噪点骤然加重，遗物用像收音机一样断裂的嗓音叫出她的名字。",
      "scene": "夜市旧物堆",
      "dialogues": [
        {
          "speaker": "Relic",
          "content": "林岚。"
        }
      ],
      "audioStatus": "locked",
      "estimatedDurationSeconds": 22,
      "revision": 1,
      "createdAt": "2026-03-28T10:05:00.000Z",
      "updatedAt": "2026-03-29T12:00:00.000Z"
    },
    {
      "id": "chapter_02_a",
      "episodeId": "episode_02",
      "index": 1,
      "title": "回廊追逐",
      "content": "林岚抱着 relic 躲进夜市后巷，头顶的投影广告一层层坠下，巡检 agent 的脚步声从深处逼近，镜头需要突出空间压缩感与角色呼吸。",
      "scene": "夜市后巷",
      "dialogues": [],
      "audioStatus": "ready",
      "estimatedDurationSeconds": 24,
      "revision": 1,
      "createdAt": "2026-04-02T10:00:00.000Z",
      "updatedAt": "2026-04-06T00:00:00.000Z"
    },
    {
      "id": "chapter_02_b",
      "episodeId": "episode_02",
      "index": 2,
      "title": "摊主交易",
      "content": "地下摊主提出用一段旧记忆换取隐藏路线，林岚在犹豫和求生之间摇摆，镜头需要从中景逐步逼近到特写，让眼神成为冲突核心。",
      "scene": "地下摊位",
      "dialogues": [
        {
          "speaker": "摊主",
          "content": "拿你的记忆换路。"
        },
        {
          "speaker": "林岚",
          "content": "我只要离开这里。"
        }
      ],
      "audioStatus": "ready",
      "estimatedDurationSeconds": 30,
      "revision": 1,
      "createdAt": "2026-04-02T10:03:00.000Z",
      "updatedAt": "2026-04-06T00:00:00.000Z"
    }
